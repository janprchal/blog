---
import MainLayout from "../layouts/MainLayout.astro";
import Link from "../components/Link.astro";
--- 

<MainLayout title="404" description="404 page in Frontend Blog" footerMessage="404 page of Astro Blog!">
  <section
    style={{
      display: "flex",
      justifyContent: "center",
      alignItems: "center",
      height: "60vh",
    }}
  >
    <div>
      <h1>404 - Page Not Found</h1>
      <p>Sorry, the page you are looking for does not exist.</p>

      <Link 
        href="/"
        text="Go back to Home"
        icon={{
          name: "mdi:home",
          side: "right"
        }}
      />
    </div>

  </section>
</MainLayout>
