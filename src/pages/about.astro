---
import MainLayout from "../layouts/MainLayout.astro";
--- 

<!-- 
  Pouzije se content ktery je v MainLayout definovat ve <slot>Default slot content</slot> 
-->
<!-- <MainLayout /> -->

<!-- 
  V tomhle pripade se nezobrazi default content ve <slot> z MainLayout, ale obsah
  footer slotu.

  Pomoci title prop se nastavi title stranky v head sekci MainLayoutu. Vsechny tyto atributy jsou pak
  dostupne v Astro.props.jmenoAtributu v MainLayoutu.
-->
<MainLayout title="About" description="About page in Frontend Blog" footerMessage="About page of Astro Blog!">
  
  <section>
    <img src="/images/headshot.jpg" alt="My Headshot" />
    <div>
      <h1>About Me</h1>
      <p>Hello! I'm a frontend developer passionate about building web applications.</p>
      <p>I love exploring new technologies and sharing my knowledge through blogging.</p>
      <p>In my free time, I enjoy hiking, photography, and reading tech articles
    </div>
  </section>
</MainLayout>
